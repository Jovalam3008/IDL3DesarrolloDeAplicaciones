[supabase]
# Copia este archivo como .streamlit/secrets.toml y reemplaza la URL.
# Recomendado para Streamlit local: Session pooler o conexion directa.
# Agrega sslmode=require si tu cadena no lo trae.
db_url = "postgresql://postgres.PROJECT_REF:TU_PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require"

